{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build", "db:generate"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"]
		},
		"lint": {
			"dependsOn": ["^build", "db:generate"]
		},
		"check-types": {
			"dependsOn": ["^build", "^check-types", "db:generate"]
		},
		"db:generate": {
			"cache": false
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
