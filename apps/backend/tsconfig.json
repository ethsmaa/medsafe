{
	"extends": "@medsafe/typescript-config/base.json",
	"compilerOptions": {
		"composite": true,
		"incremental": true,
		"noEmit": false,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"outDir": "./dist",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*", "generated/**/*", "build.mjs"]
}
